// Production schema for PostgreSQL (Supabase)
// This file is used when deploying to Vercel

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  ASSISTANT
}

enum MotoState {
  ACTIVE
  BROKEN
  MAINTENANCE
  RENTED
}

enum LivreurStatus {
  ACTIVE
  INACTIVE
}

enum ContractType {
  CDD
  CDI
  FREELANCE
}

enum LocationStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ASSISTANT)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Moto {
  id           String         @id @default(cuid())
  number       String         @unique
  name         String?
  purchaseDate DateTime?      @map("purchase_date")
  state        MotoState      @default(ACTIVE)
  lastRevision DateTime?      @map("last_revision")
  nextRevision DateTime?      @map("next_revision")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  repairs      RepairHistory[]
  assignments  Livreur[]
  locations    Location[]

  @@index([state])
  @@map("motos")
}

model RepairHistory {
  id          String   @id @default(cuid())
  motoId      String   @map("moto_id")
  moto        Moto     @relation(fields: [motoId], references: [id], onDelete: Cascade)
  description String
  date        DateTime @default(now())
  cost        Float?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([motoId])
  @@index([date])
  @@map("repair_history")
}

model Livreur {
  id           String                  @id @default(cuid())
  firstName    String                  @map("first_name")
  lastName     String                  @map("last_name")
  phone        String?
  startDate    DateTime?               @map("start_date")
  contractType ContractType            @default(CDD) @map("contract_type")
  motoId       String?                 @map("moto_id")
  moto         Moto?                   @relation(fields: [motoId], references: [id], onDelete: SetNull)
  status       LivreurStatus           @default(ACTIVE)
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  dailyRecords ComptabiliteJournaliere[]

  @@index([status])
  @@index([motoId])
  @@map("livreurs")
}

model ComptabiliteJournaliere {
  id              String   @id @default(cuid())
  livreurId       String   @map("livreur_id")
  livreur         Livreur  @relation(fields: [livreurId], references: [id], onDelete: Cascade)
  date            DateTime
  deliveries      Int      @default(0)
  amountCollected Float    @default(0) @map("amount_collected")
  expenses        Float    @default(0)
  amountToRemit   Float    @default(0) @map("amount_to_remit")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([livreurId, date])
  @@index([date])
  @@index([livreurId])
  @@map("comptabilite_journaliere")
}

model Client {
  id           String     @id @default(cuid())
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  phone        String
  address      String?
  idCardNumber String?    @map("id_card_number")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  locations    Location[]

  @@index([phone])
  @@map("clients")
}

model Location {
  id            String         @id @default(cuid())
  clientId      String         @map("client_id")
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  motoId        String         @map("moto_id")
  moto          Moto           @relation(fields: [motoId], references: [id], onDelete: Cascade)
  startDate     DateTime       @map("start_date")
  endDate       DateTime?      @map("end_date")
  dailyRate     Float          @map("daily_rate")
  depositAmount Float?         @map("deposit_amount")
  status        LocationStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([motoId])
  @@index([status])
  @@index([startDate])
  @@map("locations")
}
